# ──────────────────────────────────────────────────────────────
# Apollo Quant v2.0 — Configuration
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# Only GOOGLE_API_KEY is required. Everything else has defaults.
# The system auto-detects the best provider from available keys.

# ── AI Provider Keys ─────────────────────────────────────────
# Google Gemini — RECOMMENDED (cheapest, 1M context window)
# Get a FREE key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# OpenAI GPT (optional fallback, ~3x more expensive)
# OPENAI_API_KEY=sk-...

# Anthropic Claude (optional fallback)
# ANTHROPIC_API_KEY=sk-ant-...

# ── AI Budget & Behavior ─────────────────────────────────────
# Provider selection: google, openai, anthropic, or auto
APOLLO_AI_PROVIDER=auto
# Daily/weekly spending limits (USD)
APOLLO_DAILY_BUDGET=50.0
APOLLO_WEEKLY_BUDGET=200.0
# Model tier: 1=cheap/fast, 2=balanced (default), 3=best/expensive
APOLLO_DEFAULT_TIER=2
# Allow tier-3 models when budget permits
APOLLO_ALLOW_TIER3=true
# Max pairs to scan per cycle (more pairs = more tokens)
APOLLO_MAX_PAIRS=15

# ── Telegram Alerts (optional) ───────────────────────────────
# Setup:
#   1. Open Telegram → search @BotFather → /newbot → copy token
#   2. Send any message to your new bot
#   3. Chat ID will be auto-discovered (or set manually)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Autonomous Agent ─────────────────────────────────────────
# Base scan interval in hours (adaptive mode overrides this)
APOLLO_SCAN_INTERVAL_HOURS=2
# Adaptive scanning: 30min (volatile) → 45min (trending) → 2h (quiet)
APOLLO_ADAPTIVE_SCAN=true
# Minimum confidence to send Telegram alerts
APOLLO_ALERT_MIN_CONFIDENCE=MEDIUM
# Enable deep multi-step analysis for interesting setups
APOLLO_DEEP_ANALYSIS=true
